# Backend
DATABASE_URL=sqlite:///./digest.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
CORS_ORIGIN_REGEX=http://(localhost|127\.0\.0\.1):517[3-9]

# arXiv
ARXIV_CATEGORIES=cs.LG,cs.AI,cs.CL,cs.CV,stat.ML,quant-ph
ARXIV_MAX_RESULTS_PER_CATEGORY=40
LOOKBACK_HOURS=36
TOP_N=12
FULL_TEXT_TOP_K=6

# Scheduler
DIGEST_RUN_TIME=07:00
DIGEST_TIMEZONE=UTC
ENABLE_SCHEDULER=true

# LLM
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_SYNTHESIS_MODEL=glm-5.2
ZAI_CLASSIFIER_MODEL=glm-4.7-flashx
ZAI_SYNTHESIS_INPUT_PRICE_PER_M=1.40
ZAI_SYNTHESIS_OUTPUT_PRICE_PER_M=4.40
ZAI_CLASSIFIER_INPUT_PRICE_PER_M=0.07
ZAI_CLASSIFIER_OUTPUT_PRICE_PER_M=0.40
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
LLM_RUN_BUDGET_USD=2.0

# Dev
SEED_ON_EMPTY=true
LOG_LEVEL=info

# Frontend
VITE_API_BASE_URL=http://localhost:8000
